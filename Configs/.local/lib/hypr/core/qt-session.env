# Canonical Qt session environment — single source of truth for the shell-side
# consumers that normalize the Qt theme env:
#   - system/app2unit.sh        (--setenv on systemd-run; export on direct exec)
#   - theme/lib/desktop.sync.bash (pushes to systemd --user + DBus activation)
#
# This exists to defeat a stale value (e.g. QT_QPA_PLATFORMTHEME=gtk3) lingering
# in an already-propagated session env. Keep these in sync with core.lua's
# hl.env() Qt declarations (the Hyprland-side source).
#
# Format: one KEY=VALUE per line; blank lines and # comments ignored.
QT_QPA_PLATFORMTHEME=qt6ct
QT_STYLE_OVERRIDE=kvantum
