{
  "custom/colormode": {
    "justify": "center",
    "format": "{}",
    "exec": "hyprshell waybar.colormode.sh",
    "return-type": "json",
    "tooltip-format": "󰏙 {1} color mode",
    "on-click": "hyprshell theme/color-mode -m",
    "on-click-right": "hyprshell theme/color-mode -p",
    "on-click-middle": "hyprshell theme/color-mode -n",
    "interval": 86400,
    "signal": 8,
    "tooltip": true,
  },
}
