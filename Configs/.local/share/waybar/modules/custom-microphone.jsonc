{
  "custom/microphone": {
    "format": "{}",
    "exec": "hyprshell waybar.mic.sh",
    "return-type": "json",
    "on-click": "hyprshell volume-control -i m",
    "on-click-right": "pavucontrol -t 4",
    "on-scroll-up": "hyprshell volume-control -i i",
    "on-scroll-down": "hyprshell volume-control -i d",
    "tooltip": true,
    "interval": 5,
    "signal": 18
  }
}
