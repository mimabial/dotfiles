{
  "ext/workspaces#roman": {
    "class": "no-margin-padding",
    "all-outputs": true,
    "active-only": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch \"hl.dsp.focus({ workspace = 'r-1' })\"",
    "on-scroll-down": "hyprctl dispatch \"hl.dsp.focus({ workspace = 'r+1' })\"",
    "sort-by-name": true,
    "format": "󱘹 {icon} 󱘹",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X",
      "11": "XI",
      "12": "XII",
      "13": "XIII",
      "14": "XIV",
      "15": "XV",
      "16": "XVII",
      "17": "XVI",
      "18": "XVIII",
      "19": "XIX",
      "20": "XX",
      "default": ""
    }
  }
}
