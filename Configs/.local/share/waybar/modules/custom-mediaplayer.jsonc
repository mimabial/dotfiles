{
  "custom/mediaplayer": {
    "justify": "center",
    "exec": "hyprshell mediaplayer.py",
    "return-type": "json",
    "format": "{alt}",
    "tooltip": true,
    "on-click": "hyprshell mediaplayer.py --action play-pause",
    "on-click-right": "hyprshell mediaplayer.py --menu",
    "on-scroll-up": "hyprshell mediaplayer.py --action cycle-next",
    "on-scroll-down": "hyprshell mediaplayer.py --action cycle-previous",
    "restart-interval": 5
  }
}
