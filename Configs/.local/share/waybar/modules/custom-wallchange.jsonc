{
  "custom/wallchange": {
    "justify": "center",
    "format": "\udb80\udd8a",
    "tooltip-format": "\udb80\udd8a Switch wallpaper",
    "on-click": "hyprshell waybar.wallpaper.sh next",
    "on-click-right": "hyprshell waybar.wallpaper.sh previous",
    "on-click-middle": "hyprshell waybar.wallpaper.sh select",
    "interval": 86400,
    "tooltip": true
  }
}
