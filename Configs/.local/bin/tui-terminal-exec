#!/bin/bash

TERMINAL_TUI="${TERMINAL_TUI:-kitty}"
hypr_profile=""
hypr_width=""
hypr_height=""
app_id=""
title=""
cmd=()
terminal_launch=()

usage() {
  printf 'Usage: %s [--hypr-profile NAME] [--hypr-size WIDTH HEIGHT] [--app-id ID] [--title TITLE] -- <command> [args...]\n' "$(basename "$0")" >&2
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --hypr-profile)
        [[ "$#" -ge 2 ]] || {
          usage
          exit 2
        }
        hypr_profile="$2"
        shift 2
        ;;
      --hypr-size)
        [[ "$#" -ge 3 ]] || {
          usage
          exit 2
        }
        hypr_width="$2"
        hypr_height="$3"
        shift 3
        ;;
      --app-id)
        [[ "$#" -ge 2 ]] || {
          usage
          exit 2
        }
        app_id="$2"
        shift 2
        ;;
      --title)
        [[ "$#" -ge 2 ]] || {
          usage
          exit 2
        }
        title="$2"
        shift 2
        ;;
      --)
        shift
        cmd=("$@")
        break
        ;;
      *)
        cmd+=("$1")
        shift
        ;;
    esac
  done

  [[ "${#cmd[@]}" -gt 0 ]] || {
    usage
    exit 2
  }
}

apply_geometry_profile() {
  case "${hypr_profile}" in
    "")
      return 0
      ;;
    tui | dialog)
      hypr_width="50%"
      hypr_height="80%"
      ;;
    *)
      printf 'Unknown hypr profile: %s\n' "${hypr_profile}" >&2
      return 1
      ;;
  esac
}

resolve_percentages() {
  [[ "${hypr_width}" == *% || "${hypr_height}" == *% ]] || return 0

  local monitor_json mon_w mon_h
  monitor_json=$(hyprctl monitors -j 2>/dev/null) || return 1
  mon_w=$(jq -r '.[] | select(.focused) | (.width / .scale | floor)' <<< "${monitor_json}") || return 1
  mon_h=$(jq -r '.[] | select(.focused) | (.height / .scale | floor)' <<< "${monitor_json}") || return 1

  [[ -n "${mon_w}" && -n "${mon_h}" ]] || return 1

  if [[ "${hypr_width}" == *% ]]; then
    hypr_width=$(( ${hypr_width%\%} * mon_w / 100 ))
  fi
  if [[ "${hypr_height}" == *% ]]; then
    hypr_height=$(( ${hypr_height%\%} * mon_h / 100 ))
  fi
}

validate_exec_command() {
  if [[ "${cmd[0]}" == */* ]]; then
    [[ -x "${cmd[0]}" ]] && return 0
  elif command -v "${cmd[0]}" >/dev/null 2>&1; then
    return 0
  fi

  printf 'Command not found: %s\n' "${cmd[0]}" >&2
  return 127
}

build_terminal_command() {
  local terminal_name="${TERMINAL_TUI##*/}"

  terminal_launch=("${TERMINAL_TUI}")

  case "${terminal_name}" in
    kitty)
      [[ -n "${app_id}" ]] && terminal_launch+=("--app-id=${app_id}")
      [[ -n "${title}" ]] && terminal_launch+=("--title=${title}")
      terminal_launch+=("${cmd[@]}")
      ;;
    alacritty)
      [[ -n "${app_id}" ]] && terminal_launch+=(--class "${app_id}")
      [[ -n "${title}" ]] && terminal_launch+=(--title "${title}")
      terminal_launch+=(-e "${cmd[@]}")
      ;;
    *)
      if [[ -n "${app_id}" || -n "${title}" ]]; then
        printf 'WARN: terminal backend %s does not support app-id/title metadata\n' "${terminal_name}" >&2
      fi
      terminal_launch+=("${cmd[@]}")
      ;;
  esac
}

inject_window_rules() {
  [[ -n "${app_id}" ]] || return 1
  command -v hyprctl >/dev/null 2>&1 || return 1

  local match="match:class ^(${app_id//./\\.})$"
  hyprctl -q --batch \
    "keyword windowrule float 1, ${match}; \
keyword windowrule size ${hypr_width} ${hypr_height}, ${match}; \
keyword windowrule center 1, ${match}" \
    >/dev/null 2>&1
}

remove_window_rules() {
  [[ -n "${app_id}" ]] || return 0
  command -v hyprctl >/dev/null 2>&1 || return 0

  local match="match:class ^(${app_id//./\\.})$"
  hyprctl -q --batch \
    "keyword windowruleremove float 1, ${match}; \
keyword windowruleremove size ${hypr_width} ${hypr_height}, ${match}; \
keyword windowruleremove center 1, ${match}" \
    >/dev/null 2>&1 || true
}

terminate_child() {
  kill -TERM "${terminal_pid}" 2>/dev/null || true
}

parse_args "$@"
apply_geometry_profile || exit 2
resolve_percentages || true
validate_exec_command || exit $?
build_terminal_command

if [[ -n "${hypr_width}" && -n "${hypr_height}" ]]; then
  inject_window_rules || true
fi

"${terminal_launch[@]}" &
terminal_pid=$!

trap terminate_child INT TERM HUP
wait "${terminal_pid}"

if [[ -n "${hypr_width}" && -n "${hypr_height}" ]]; then
  remove_window_rules
fi
