#!/usr/bin/env bash
#
# tui-terminal-exec — Launch a command in a TUI terminal with optional Hyprland metadata.
#
# Usage: tui-terminal-exec [--hypr-profile NAME] [--hypr-size WIDTH HEIGHT] [--app-id ID] [--title TITLE] -- <command> [args...]
# Depends on: terminal emulator, hyprctl, jq
#
set -euo pipefail

TERMINAL_TUI="${TERMINAL_TUI:-kitty}"
hypr_profile=""
hypr_width=""
hypr_height=""
app_id=""
title=""
print_path=0
print_cmd=0
print_cmd_sep=$'\037'
cmd=()
terminal_args=()
terminal_launch=()

usage() {
  printf 'Usage: %s [--hypr-profile NAME] [--hypr-size WIDTH HEIGHT] [--app-id ID] [--title TITLE] [--] [command [args...]]\n' "$(basename "$0")" >&2
}

require_option_args() {
  local option_name="$1"
  local required_argc="$2"

  [[ "$#" -ge "${required_argc}" ]] && return 0
  printf 'Missing argument for %s\n' "${option_name}" >&2
  usage
  exit 2
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --hypr-profile=*)
        hypr_profile="${1#--hypr-profile=}"
        shift
        ;;
      --hypr-profile)
        require_option_args "$1" 2 "$@"
        hypr_profile="$2"
        shift 2
        ;;
      --hypr-size=*)
        hypr_width="${1#--hypr-size=}"
        if [[ "${hypr_width}" != *,* ]]; then
          printf 'Expected --hypr-size=WIDTH,HEIGHT\n' >&2
          usage
          exit 2
        fi
        hypr_height="${hypr_width#*,}"
        hypr_width="${hypr_width%%,*}"
        [[ -n "${hypr_width}" && -n "${hypr_height}" ]] || {
          printf 'Expected --hypr-size=WIDTH,HEIGHT\n' >&2
          usage
          exit 2
        }
        shift
        ;;
      --hypr-size)
        require_option_args "$1" 3 "$@"
        hypr_width="$2"
        hypr_height="$3"
        shift 3
        ;;
      --app-id=*)
        app_id="${1#--app-id=}"
        shift
        ;;
      --app-id)
        require_option_args "$1" 2 "$@"
        app_id="$2"
        shift 2
        ;;
      --title=*)
        title="${1#--title=}"
        shift
        ;;
      --title)
        require_option_args "$1" 2 "$@"
        title="$2"
        shift 2
        ;;
      --print-path)
        print_path=1
        shift
        ;;
      --print-cmd)
        print_cmd=1
        shift
        ;;
      --print-cmd=*)
        print_cmd=1
        print_cmd_sep="$(printf '%b' "${1#--print-cmd=}")"
        shift
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      --)
        shift
        cmd=("$@")
        break
        ;;
      -*)
        terminal_args+=("$1")
        shift
        ;;
      *)
        cmd=("$@")
        break
        ;;
    esac
  done
}

apply_geometry_profile() {
  case "${hypr_profile}" in
    "")
      return 0
      ;;
    tui | dialog)
      hypr_width="50%"
      hypr_height="80%"
      ;;
    *)
      printf 'Unknown hypr profile: %s\n' "${hypr_profile}" >&2
      return 1
      ;;
  esac
}

resolve_percentages() {
  [[ "${hypr_width}" == *% || "${hypr_height}" == *% ]] || return 0

  local monitor_json mon_w mon_h

  command -v hyprctl >/dev/null 2>&1 || {
    printf 'Cannot resolve percentage geometry without hyprctl\n' >&2
    return 1
  }
  command -v jq >/dev/null 2>&1 || {
    printf 'Cannot resolve percentage geometry without jq\n' >&2
    return 1
  }

  monitor_json=$(hyprctl monitors -j 2>/dev/null) || return 1
  read -r mon_w mon_h < <(
    jq -r '.[] | select(.focused) | "\(.width / .scale | floor) \(.height / .scale | floor)"' <<<"${monitor_json}"
  ) || return 1

  [[ "${mon_w}" =~ ^[0-9]+$ && "${mon_h}" =~ ^[0-9]+$ ]] || {
    printf 'Cannot determine focused monitor size for percentage geometry\n' >&2
    return 1
  }

  if [[ "${hypr_width}" == *% ]]; then
    hypr_width=$(( ${hypr_width%\%} * mon_w / 100 ))
  fi
  if [[ "${hypr_height}" == *% ]]; then
    hypr_height=$(( ${hypr_height%\%} * mon_h / 100 ))
  fi
}

validate_exec_command() {
  ((${#cmd[@]} > 0)) || return 0

  if [[ "${cmd[0]}" == */* ]]; then
    [[ -x "${cmd[0]}" ]] && return 0
  elif command -v "${cmd[0]}" >/dev/null 2>&1; then
    return 0
  fi

  printf 'Command not found: %s\n' "${cmd[0]}" >&2
  return 127
}

build_terminal_command() {
  local terminal_name="${TERMINAL_TUI##*/}"

  terminal_launch=("${TERMINAL_TUI}" "${terminal_args[@]}")

  case "${terminal_name}" in
    kitty)
      [[ -n "${app_id}" ]] && terminal_launch+=("--app-id=${app_id}")
      [[ -n "${title}" ]] && terminal_launch+=("--title=${title}")
      terminal_launch+=("${cmd[@]}")
      ;;
    alacritty)
      [[ -n "${app_id}" ]] && terminal_launch+=(--class "${app_id}")
      [[ -n "${title}" ]] && terminal_launch+=(--title "${title}")
      ((${#cmd[@]} > 0)) && terminal_launch+=(-e "${cmd[@]}")
      ;;
    *)
      if [[ -n "${app_id}" || -n "${title}" ]]; then
        printf 'WARN: terminal backend %s does not support app-id/title metadata\n' "${terminal_name}" >&2
      fi
      terminal_launch+=("${cmd[@]}")
      ;;
  esac
}

terminal_desktop_path() {
  local terminal_name="${TERMINAL_TUI##*/}"
  local candidate=""
  local -a app_dirs=(
    "${XDG_DATA_HOME:-$HOME/.local/share}/applications"
    "/usr/local/share/applications"
    "/usr/share/applications"
  )

  for candidate in \
    "${terminal_name}.desktop" \
    "org.${terminal_name}.${terminal_name}.desktop" \
    "org.${terminal_name}.desktop"; do
    local app_dir=""
    for app_dir in "${app_dirs[@]}"; do
      [[ -f "${app_dir}/${candidate}" ]] || continue
      printf '%s\n' "${app_dir}/${candidate}"
      return 0
    done
  done

  return 1
}

print_terminal_target() {
  local desktop_path=""
  local joined_cmd=""

  build_terminal_command

  if [[ "${print_path}" -eq 1 ]]; then
    desktop_path="$(terminal_desktop_path)" || return 1
    printf '%s' "${desktop_path}"
  fi

  if [[ "${print_cmd}" -eq 1 ]]; then
    ((${print_path} == 1)) && printf '\n'
    if ((${#terminal_launch[@]} > 0)); then
      printf -v joined_cmd "%s${print_cmd_sep}" "${terminal_launch[@]}"
      printf '%s' "${joined_cmd%"${print_cmd_sep}"}"
    fi
  fi
}

inject_window_rules() {
  [[ -n "${app_id}" ]] || return 1
  command -v hyprctl >/dev/null 2>&1 || return 1

  local match="match:class ^(${app_id//./\\.})$"
  hyprctl -q --batch \
    "keyword windowrule float 1, ${match}; \
keyword windowrule size ${hypr_width} ${hypr_height}, ${match}; \
keyword windowrule center 1, ${match}" \
    >/dev/null 2>&1
}

remove_window_rules() {
  [[ -n "${app_id}" ]] || return 0
  command -v hyprctl >/dev/null 2>&1 || return 0

  local match="match:class ^(${app_id//./\\.})$"
  hyprctl -q --batch \
    "keyword windowruleremove float 1, ${match}; \
keyword windowruleremove size ${hypr_width} ${hypr_height}, ${match}; \
keyword windowruleremove center 1, ${match}" \
    >/dev/null 2>&1 || true
}

terminate_child() {
  kill -TERM "${terminal_pid}" 2>/dev/null || true
}

main() {
  local exit_code=0

  parse_args "$@"
  apply_geometry_profile || return 2
  resolve_percentages || return 2

  if [[ "${print_path}" -eq 1 || "${print_cmd}" -eq 1 ]]; then
    print_terminal_target
    return $?
  fi

  validate_exec_command || return $?
  build_terminal_command

  if [[ -n "${hypr_width}" && -n "${hypr_height}" ]]; then
    inject_window_rules || true
  fi

  "${terminal_launch[@]}" &
  terminal_pid=$!

  trap terminate_child INT TERM HUP
  wait "${terminal_pid}" || exit_code=$?

  if [[ -n "${hypr_width}" && -n "${hypr_height}" ]]; then
    remove_window_rules
  fi

  return "${exit_code}"
}

main "$@"
