#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=/dev/null
source "${HOME}/.local/bin/.common.bash"

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles/Configs}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/hypr"
STATE_FILE="${STATE_DIR}/host-profile"
SYNC_MANIFEST_FILE="${DOTFILES_SYNC_MANIFEST:-${XDG_CONFIG_HOME:-$HOME/.config}/hypr/dotfiles-sync.conf}"

usage() {
  cat <<USAGE
Usage: $(basename "$0") <command> [args]
Commands:
  show                Print the selected host profile
  list                List available host profiles from dotfiles
  path [profile]      Print the dotfiles path for a host profile
  set <profile>       Select a host profile and create its dotfiles directory
  apply [profile]     Apply a host profile onto the live config paths
  apply --dry-run     Preview host profile changes without writing
  help                Show this help
USAGE
}

require_rsync() {
  command -v rsync >/dev/null 2>&1 || die "rsync is required"
}

require_sync_manifest() {
  [[ -r "${SYNC_MANIFEST_FILE}" ]] || die "Sync manifest not found: ${SYNC_MANIFEST_FILE}"
}

path_exists() {
  [[ -e "$1" || -L "$1" ]]
}

validate_profile() {
  local profile="${1:-}"
  [[ -n "${profile}" && "${profile}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || \
    die "Invalid host profile: ${profile:-<empty>}"
}

current_profile() {
  local profile=""
  [[ -f "${STATE_FILE}" ]] || return 1
  read -r profile <"${STATE_FILE}" || true
  validate_profile "${profile}"
  printf '%s\n' "${profile}"
}

profile_dir() {
  local profile="$1"
  validate_profile "${profile}"
  printf '%s\n' "${DOTFILES_DIR}/hosts/${profile}"
}

list_profiles() {
  local hosts_dir="${DOTFILES_DIR}/hosts"

  [[ -d "${hosts_dir}" ]] || return 0
  find "${hosts_dir}" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
}

set_profile() {
  local profile="$1"

  validate_profile "${profile}"
  mkdir -p "${STATE_DIR}" "$(profile_dir "${profile}")"
  printf '%s\n' "${profile}" >"${STATE_FILE}"
  printf 'Selected host profile: %s\n' "${profile}"
  printf 'Dotfiles path: %s\n' "$(profile_dir "${profile}")"
}

apply_profile() {
  local profile="$1"
  local dry_run="$2"
  local host_dir=""
  local rel=""
  local applied=0
  local kind=""
  local excludes=""
  local extra=""
  local -a host_targets=()

  if [[ -z "${profile}" ]]; then
    profile="$(current_profile || true)"
  fi
  [[ -n "${profile}" ]] || die "No host profile selected. Use dotfiles-host-profile set <profile>."
  validate_profile "${profile}"

  host_dir="$(profile_dir "${profile}")"
  [[ -d "${host_dir}" ]] || die "Host profile directory does not exist: ${host_dir}"

  require_rsync
  require_sync_manifest

  while IFS='|' read -r kind rel excludes extra; do
    [[ -n "${kind}${rel}${excludes}${extra}" ]] || continue
    [[ "${kind}" == \#* ]] && continue
    [[ -z "${extra}" ]] || die "Invalid manifest entry: ${kind}|${rel}|${excludes}|${extra}"
    [[ "${kind}" == "host" ]] || continue
    [[ -n "${rel}" ]] || die "Invalid host manifest entry: ${kind}|${rel}|${excludes}"
    host_targets+=("${rel}")
  done < "${SYNC_MANIFEST_FILE}"

  printf 'Applying host profile: %s\n' "${profile}"
  printf 'Source: %s\n' "${host_dir}"
  $dry_run && echo '(DRY RUN - no changes will be made)'

  for rel in "${host_targets[@]}"; do
    if apply_target "${host_dir}" "${rel}" "${dry_run}"; then
      applied=1
    fi
  done

  (( applied == 1 )) || printf 'No managed host files defined for %s\n' "${profile}"
}

ensure_empty_target() {
  local dest="$1"
  mkdir -p "$(dirname "${dest}")"
  if [[ -d "${dest}" && ! -L "${dest}" ]]; then
    rm -rf -- "${dest}"
  fi
  : >"${dest}"
}

apply_target() {
  local host_dir="$1"
  local rel="$2"
  local dry_run="$3"
  local src="${host_dir}/${rel}"
  local nested_src=""
  local dest="${HOME}/${rel}"
  local output=""

  if [[ "${rel}" == ".config/hypr/gpu.lua" ]] && ! path_exists "${src}"; then
    nested_src="$(find "${host_dir}/.config/hypr" -mindepth 2 -maxdepth 2 \
      \( -type f -o -type l \) -name "$(basename -- "${rel}")" -print -quit 2>/dev/null || true)"
    if [[ -n "${nested_src}" ]] && path_exists "${nested_src}"; then
      src="${nested_src}"
    fi
  fi

  if path_exists "${src}"; then
    if $dry_run; then
      if ! output=$(rsync -a --mkpath --dry-run --itemize-changes "${src}" "${dest}" 2>&1); then
        die "Preview failed for ${rel}: ${output}"
      fi
    else
      if ! output=$(rsync -a --mkpath --itemize-changes "${src}" "${dest}" 2>&1); then
        die "Apply failed for ${rel}: ${output}"
      fi
    fi

    if [[ -n "${output}" ]]; then
      printf 'Changes for %s:\n%s\n' "${rel}" "${output}"
    else
      printf 'Unchanged: %s\n' "${rel}"
    fi
    return 0
  fi

  if [[ "${rel}" == ".config/hypr/gpu.lua" ]]; then
    if $dry_run; then
      if [[ -f "${dest}" && ! -s "${dest}" ]]; then
        printf 'Unchanged: %s\n' "${rel}"
      else
        printf 'Changes for %s:\n>f+++++++++ %s\n' "${rel}" "${rel}"
      fi
    else
      ensure_empty_target "${dest}"
      printf 'Ensured empty fallback: %s\n' "${rel}"
    fi
    return 0
  fi

  path_exists "${dest}" || return 1

  if $dry_run; then
    printf 'Changes for %s:\n*deleting   %s\n' "${rel}" "${rel}"
  else
    rm -rf -- "${dest}"
    printf 'Removed: %s\n' "${rel}"
  fi

  return 0
}

command_name="${1:-show}"
shift $(( $# > 0 ? 1 : 0 ))

case "${command_name}" in
  show)
    if profile="$(current_profile 2>/dev/null)"; then
      printf '%s\n' "${profile}"
    else
      echo '(not set)'
    fi
    ;;
  list)
    list_profiles
    ;;
  path)
    if [[ $# -gt 0 ]]; then
      profile="$1"
    else
      profile="$(current_profile || true)"
    fi
    [[ -n "${profile}" ]] || die "No host profile selected. Use dotfiles-host-profile set <profile>."
    profile_dir "${profile}"
    ;;
  set)
    [[ $# -ge 1 ]] || die "Usage: $(basename "$0") set <profile>"
    profile="$1"
    set_profile "${profile}"
    if [[ "${2:-}" == "--apply" ]]; then
      apply_profile "${profile}" false
    fi
    ;;
  apply)
    dry_run=false
    profile=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --dry-run) dry_run=true ;;
        -h|--help)
          usage
          exit 0
          ;;
        *)
          [[ -z "${profile}" ]] || die "Only one profile may be provided"
          profile="$1"
          ;;
      esac
      shift
    done
    apply_profile "${profile}" "${dry_run}"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    die "Unknown command: ${command_name}"
    ;;
esac
