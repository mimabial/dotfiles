#!/usr/bin/env bash
# Sync configuration files to dotfiles directory
# Usage: dotfiles-sync [--dry-run|--list]

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles/Configs}"
DRY_RUN=false
LIST_ONLY=false
HOST_PROFILE_STATE_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/hypr/host-profile"
HOST_TARGETS=(
  ".config/hypr/monitors.conf"
  ".config/hypr/gpu.conf"
  ".config/waybar/modules/temperature.jsonc"
  ".local/state/hypr/env-overrides"
)

usage() {
  cat <<USAGE
Usage: $(basename "$0") [options]
Options:
  --dry-run   Preview actual sync changes without writing
  --list      List configured sync mappings only
  -h, --help  Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "${1}" in
    --dry-run) DRY_RUN=true ;;
    --list) LIST_ONLY=true ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: ${1}" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

emit_preview_result() {
  local name="$1"
  local output="$2"

  log_info "Preview $name"
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    echo "No changes."
  fi
}

emit_apply_result() {
  local name="$1"
  local output="$2"

  if [[ -n "$output" ]]; then
    log_success "Updated $name"
  else
    log_info "Unchanged $name"
  fi
}

run_rsync_transfer() {
  local name="$1"
  local log_failures="${2:-true}"
  shift 2
  local output=""
  local -a rsync_args=("$@")

  if $DRY_RUN; then
    rsync_args+=(--dry-run --itemize-changes)
    if ! output=$(rsync "${rsync_args[@]}" 2>&1); then
      if [[ "${log_failures}" == true ]]; then
        log_error "Preview failed for $name"
        printf '%s\n' "$output" >&2
      fi
      return 1
    fi
    emit_preview_result "$name" "$output"
    return 0
  fi

  rsync_args+=(--itemize-changes)
  if ! output=$(rsync "${rsync_args[@]}" 2>&1); then
    if [[ "${log_failures}" == true ]]; then
      log_error "Sync failed for $name"
      printf '%s\n' "$output" >&2
    fi
    return 1
  fi
  emit_apply_result "$name" "$output"
}

require_rsync() {
  if ! command -v rsync &>/dev/null; then
    log_error "rsync is required (cp fallback removed). Install rsync and rerun."
    exit 1
  fi
}

host_profile_is_valid() {
  local profile="${1:-}"
  [[ -n "${profile}" && "${profile}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]
}

get_host_profile() {
  local profile=""

  if [[ -f "${HOST_PROFILE_STATE_FILE}" ]]; then
    read -r profile <"${HOST_PROFILE_STATE_FILE}" || true
  fi

  if [[ -n "${profile}" ]] && ! host_profile_is_valid "${profile}"; then
    log_warn "Ignoring invalid host profile in ${HOST_PROFILE_STATE_FILE}: ${profile}"
    return 1
  fi

  [[ -n "${profile}" ]] || return 1
  printf '%s\n' "${profile}"
}

remove_path() {
  local dest="$1"
  local name="$2"
  local rel_dest="${dest#${DOTFILES_DIR}/}"

  if $LIST_ONLY; then
    echo "PLAN ABSENT ${dest}"
    return
  fi

  if [[ ! -e "${dest}" && ! -L "${dest}" ]]; then
    return
  fi

  if $DRY_RUN; then
    emit_preview_result "${name}" "*deleting   ${rel_dest}"
    return
  fi

  rm -rf -- "${dest}"
  log_success "Removed ${name}"
}

sync_host_profile_files() {
  local profile=""
  local host_root=""
  local target=""

  if profile="$(get_host_profile)"; then
    host_root="${DOTFILES_DIR}/hosts/${profile}"
  else
    log_warn "No host profile selected; managed host-specific files will not be saved. Use dotfiles-host-profile set <profile>."
  fi

  for target in "${HOST_TARGETS[@]}"; do
    remove_path "${DOTFILES_DIR}/${target}" "root host file ${target}"
  done

  if [[ -z "${host_root}" ]]; then
    return
  fi

  if $LIST_ONLY; then
    log_info "Planning host profile mappings (${profile})..."
  else
    log_info "Syncing host profile '${profile}'..."
  fi

  for target in "${HOST_TARGETS[@]}"; do
    copy_file "${HOME}/${target}" "${host_root}/${target}" "hosts/${profile}/${target}"
  done
}

# Create dotfiles directory structure
create_dirs() {
  local dirs=(
    "$DOTFILES_DIR/.config"
    "$DOTFILES_DIR/.local/bin"
    "$DOTFILES_DIR/.local/lib"
    "$DOTFILES_DIR/.local/share"
    "$DOTFILES_DIR/hosts"
  )

  for dir in "${dirs[@]}"; do
    if $LIST_ONLY; then
      echo "PLAN DIR    $dir"
    elif $DRY_RUN; then
      echo "Would create: $dir"
    else
      mkdir -p "$dir"
    fi
  done
}

# Copy a config directory
copy_config() {
  local src="$1"
  local dest="$2"
  local name="$3"
  shift 3
  local extra_excludes=("$@")
  local rsync_args=()
  local output=""
  local exclude_pattern=""
  local exclude_preview=""

  if $LIST_ONLY; then
    if ((${#extra_excludes[@]})); then
      exclude_preview="$(printf '%s, ' "${extra_excludes[@]}")"
      exclude_preview="${exclude_preview%, }"
      echo "PLAN DIR    $src -> $dest (exclude: $exclude_preview)"
    else
      echo "PLAN DIR    $src -> $dest"
    fi
    return
  fi

  if [[ ! -e "$src" ]]; then
    log_warn "Skipping $name (not found: $src)"
    return
  fi

  if [[ ! -d "$src" ]]; then
    copy_file "$src" "$dest" "$name"
    return
  fi

  rsync_args=(
    -a
    --mkpath
    --delete
    --delete-excluded
    --exclude='.git'
    --exclude='__pycache__'
    --exclude='*.pyc'
    --exclude='node_modules'
    --exclude='.cache'
    --exclude='lazy-lock.json'
  )
  for exclude_pattern in "${extra_excludes[@]}"; do
    rsync_args+=(--exclude="$exclude_pattern")
  done

  run_rsync_transfer "$name" true "${rsync_args[@]}" "$src"/ "$dest"/
}

# Copy a single file
copy_file() {
  local src="$1"
  local dest="$2"
  local name="$3"
  local rsync_args=(-a --mkpath)
  local output=""

  if $LIST_ONLY; then
    echo "PLAN FILE   $src -> $dest"
    return
  fi

  if [[ ! -e "$src" && ! -L "$src" ]]; then
    if [[ -e "$dest" || -L "$dest" ]]; then
      if $DRY_RUN; then
        emit_preview_result "$name" "*deleting   $(basename "$dest")"
      else
        rm -rf -- "$dest"
        log_success "Removed stale $name"
      fi
    else
      log_warn "Skipping $name (not found: $src)"
    fi
    return
  fi

  if [[ -d "$dest" && ! -L "$dest" ]]; then
    if $DRY_RUN; then
      emit_preview_result "$name" $'*deleting   '"$(basename "$dest")"$'\n>f+++++++++ '"$(basename "$dest")"
      return
    fi
    rm -rf -- "$dest"
  fi

  if run_rsync_transfer "$name" false "${rsync_args[@]}" "$src" "$dest"; then
    return 0
  fi

  if [[ ! -d "$(dirname "$dest")" && "$(basename "$src")" == "$(basename "$dest")" ]]; then
    run_rsync_transfer "$name" true "${rsync_args[@]}" "$src" "$(dirname "$dest")"/
    return
  fi

  return 1
}

echo "========================================="
echo "  Dotfiles Sync"
echo "========================================="
echo "Target: $DOTFILES_DIR"
if profile="$(get_host_profile 2>/dev/null)"; then
  echo "Host profile: ${profile}"
else
  echo "Host profile: (not set)"
fi
$DRY_RUN && echo "(DRY RUN - no changes will be made)"
$LIST_ONLY && echo "(LIST MODE - plan only, no checks or filesystem writes)"
echo

if ! $LIST_ONLY; then
  require_rsync
fi

# Create directory structure
if $LIST_ONLY; then
  log_info "Planning directory structure..."
else
  log_info "Creating directory structure..."
fi
create_dirs
echo

# ~/.config directories
if $LIST_ONLY; then
  log_info "Planning ~/.config mappings..."
else
  log_info "Syncing ~/.config..."
fi

# Hyprland ecosystem
copy_config "$HOME/.config/hypr" "$DOTFILES_DIR/.config/hypr" "hypr" \
  "monitors.conf" \
  "gpu.conf" \
  "themes/colors.conf" \
  "themes/theme.conf" \
  "themes/wal.conf" \
  "hyprlock/colors.conf" \
  "shaders/.compiled.cache.glsl"
copy_config "$HOME/.config/waybar" "$DOTFILES_DIR/.config/waybar" "waybar" \
  "modules/temperature.jsonc" \
  "colors.css" \
  "theme.generated.css" \
  "includes/border-radius.css" \
  "includes/font.css" \
  "includes/global.css" \
  "includes/includes.json"
copy_config "$HOME/.config/rofi" "$DOTFILES_DIR/.config/rofi" "rofi" \
  "colors.rasi" \
  "theme.generated.rasi"
copy_config "$HOME/.config/dunst" "$DOTFILES_DIR/.config/dunst" "dunst" \
  "dunstrc" \
  "theme.conf" \
  "theme.generated.conf"
copy_config "$HOME/.config/wlogout" "$DOTFILES_DIR/.config/wlogout" "wlogout"

# Terminals
copy_config "$HOME/.config/kitty" "$DOTFILES_DIR/.config/kitty" "kitty" \
  "colors.conf" \
  "theme.generated.conf"
copy_config "$HOME/.config/alacritty" "$DOTFILES_DIR/.config/alacritty" "alacritty" \
  "colors.toml" \
  "theme.generated.toml"

# Shell
copy_config "$HOME/.config/zsh" "$DOTFILES_DIR/.config/zsh" "zsh" \
  ".zcompdump" \
  ".zsh_history"
copy_file "$HOME/.zshenv" "$DOTFILES_DIR/.zshenv" ".zshenv"

# Theming
copy_config "$HOME/.config/wal" "$DOTFILES_DIR/.config/wal" "wal"
copy_config "$HOME/.config/Kvantum" "$DOTFILES_DIR/.config/Kvantum" "Kvantum"
copy_config "$HOME/.config/gtk-3.0" "$DOTFILES_DIR/.config/gtk-3.0" "gtk-3.0" \
  "colors.css"

# Other apps
copy_config "$HOME/.config/qt5ct" "$DOTFILES_DIR/.config/qt5ct" "qt5ct" \
  "colors.conf"
copy_config "$HOME/.config/qt6ct" "$DOTFILES_DIR/.config/qt6ct" "qt6ct" \
  "colors.conf"
copy_config "$HOME/.config/qutebrowser" "$DOTFILES_DIR/.config/qutebrowser" "qutebrowser"
copy_config "$HOME/.config/nwg-look" "$DOTFILES_DIR/.config/nwg-look" "nwg-look"
copy_config "$HOME/.config/menus" "$DOTFILES_DIR/.config/menus" "menus"
copy_config "$HOME/.config/vim" "$DOTFILES_DIR/.config/vim" "vim" \
  ".netrwhist"
copy_config "$HOME/.config/xsettingsd" "$DOTFILES_DIR/.config/xsettingsd" "xsettingsd"
copy_config "$HOME/.config/rmpc" "$DOTFILES_DIR/.config/rmpc" "rmpc" \
  "themes/pywal16.ron" \
  "themes/pywal16-big.ron" \
  "themes/pywal16-small.ron"
copy_config "$HOME/.config/systemd" "$DOTFILES_DIR/.config/systemd" "systemd"
copy_config "$HOME/.config/uwsm" "$DOTFILES_DIR/.config/uwsm" "uwsm"
copy_file "$HOME/.config/xdg-terminals.list" "$DOTFILES_DIR/.config/xdg-terminals.list" "xdg-terminals.list"
copy_file "$HOME/.config/kdeglobals" "$DOTFILES_DIR/.config/kdeglobals" "kdeglobals"
copy_file "$HOME/.config/baloofilerc" "$DOTFILES_DIR/.config/baloofilerc" "baloofilerc"
copy_file "$HOME/.config/dolphinrc" "$DOTFILES_DIR/.config/dolphinrc" "dolphinrc"
copy_file "$HOME/.config/satty/config.toml" "$DOTFILES_DIR/.config/satty/config.toml" "satty/config.toml"
copy_file "$HOME/.config/mpd/mpd.conf" "$DOTFILES_DIR/.config/mpd/mpd.conf" "mpd/mpd.conf"
copy_file "$HOME/.config/yt-dlp/config" "$DOTFILES_DIR/.config/yt-dlp/config" "yt-dlp/config"
copy_file "$HOME/.config/bat/config" "$DOTFILES_DIR/.config/bat/config" "bat/config"
copy_config "$HOME/.config/tmux" "$DOTFILES_DIR/.config/tmux" "tmux" \
  "plugins/" \
  "colors.conf" \
  "theme.generated.conf"
copy_config "$HOME/.config/starship.toml" "$DOTFILES_DIR/.config/starship.toml" "starship"
copy_config "$HOME/.config/fastfetch" "$DOTFILES_DIR/.config/fastfetch" "fastfetch"
copy_config "$HOME/.config/cava" "$DOTFILES_DIR/.config/cava" "cava"
sync_host_profile_files

echo

# ~/.local directories
if $LIST_ONLY; then
  log_info "Planning ~/.local mappings..."
else
  log_info "Syncing ~/.local..."
fi

# Scripts library
copy_config "$HOME/.local/lib/hypr" "$DOTFILES_DIR/.local/lib/hypr" "lib/hypr scripts"

# Share files (explicit allowlist)
copy_config "$HOME/.local/share/fonts" "$DOTFILES_DIR/.local/share/fonts" "share/fonts"
copy_config "$HOME/.local/share/hypr" "$DOTFILES_DIR/.local/share/hypr" "share/hypr"
copy_config "$HOME/.local/share/waybar" "$DOTFILES_DIR/.local/share/waybar" "share/waybar"
copy_config "$HOME/.local/share/rofi" "$DOTFILES_DIR/.local/share/rofi" "share/rofi"
copy_config "$HOME/.local/share/icons" "$DOTFILES_DIR/.local/share/icons" "share/icons"
copy_config "$HOME/.local/share/themes" "$DOTFILES_DIR/.local/share/themes" "share/themes"

# Sync ~/.local/bin as a real mirror, excluding the claude launcher symlink
if $LIST_ONLY; then
  log_info "Planning ~/.local/bin mappings (excluding claude)..."
else
  log_info "Syncing ~/.local/bin (excluding claude)..."
fi
copy_config "$HOME/.local/bin" "$DOTFILES_DIR/.local/bin" "bin" "claude"

echo
echo "========================================="
if $LIST_ONLY; then
  echo "List complete."
elif $DRY_RUN; then
  echo "Dry run complete. Run without --dry-run to apply."
else
  log_success "Dotfiles sync complete!"
  echo "Location: $DOTFILES_DIR"
fi
echo "========================================="
