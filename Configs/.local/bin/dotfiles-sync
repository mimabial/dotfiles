#!/usr/bin/env bash
# Sync configuration files to dotfiles directory
# Usage: dotfiles-sync [--dry-run|--list] [--manifest <file>]

set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles/Configs}"
DRY_RUN=false
LIST_ONLY=false
HOST_PROFILE_STATE_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/hypr/host-profile"
DEFAULT_SYNC_MANIFEST_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/dotfiles-sync.conf"
SYNC_MANIFEST_SOURCE="${DOTFILES_SYNC_MANIFEST:-${DEFAULT_SYNC_MANIFEST_FILE}}"
SYNC_MANIFEST_FILE=""
SYNC_MANIFEST_TEMP_FILE=""
ACTIVE_HOST_PROFILE=""
declare -a SYNC_MANIFEST_RECORDS=()

usage() {
  cat <<USAGE
Usage: $(basename "$0") [options]
Options:
  --dry-run   Preview actual sync changes without writing
  --list      List configured sync mappings only
  --manifest  Use a specific manifest file
  -h, --help  Show this help
USAGE
}

while [[ $# -gt 0 ]]; do
  case "${1}" in
    --dry-run) DRY_RUN=true ;;
    --list) LIST_ONLY=true ;;
    --manifest)
      [[ $# -ge 2 ]] || {
        echo "--manifest requires a file path" >&2
        usage >&2
        exit 1
      }
      SYNC_MANIFEST_SOURCE="${2}"
      shift
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: ${1}" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { printf '%b[INFO]%b %s\n' "${BLUE}" "${NC}" "$1"; }
log_success() { printf '%b[OK]%b %s\n' "${GREEN}" "${NC}" "$1"; }
log_warn() { printf '%b[WARN]%b %s\n' "${YELLOW}" "${NC}" "$1"; }
log_error() { printf '%b[ERROR]%b %s\n' "${RED}" "${NC}" "$1"; }

cleanup_temp_manifest() {
  [[ -n "${SYNC_MANIFEST_TEMP_FILE}" ]] || return 0
  rm -f -- "${SYNC_MANIFEST_TEMP_FILE}"
}

trap cleanup_temp_manifest EXIT

path_is_within_root() {
  local path="$1"
  local root="$2"

  [[ "${path}" == "${root}" || "${path}" == "${root}/"* ]]
}

relative_path_from() {
  local base_dir="$1"
  local target_path="$2"

  realpath -m --relative-to="${base_dir}" "${target_path}"
}

normalize_synced_symlink() {
  local src_root="$1"
  local dest_root="$2"
  local dest_link="$3"
  local link_target=""
  local mapped_target=""
  local relative_target=""

  [[ -L "${dest_link}" ]] || return 0
  link_target="$(readlink -- "${dest_link}")" || return 1
  [[ "${link_target}" == /* ]] || return 0
  path_is_within_root "${link_target}" "${src_root}" || return 0

  mapped_target="${dest_root}${link_target#"${src_root}"}"
  relative_target="$(relative_path_from "$(dirname -- "${dest_link}")" "${mapped_target}")"
  ln -snf -- "${relative_target}" "${dest_link}"
}

normalize_synced_internal_symlinks() {
  local src_root="$1"
  local dest_root="$2"
  local path=""

  if [[ -L "${dest_root}" ]]; then
    normalize_synced_symlink "${src_root}" "${dest_root}" "${dest_root}"
    return
  fi

  [[ -d "${dest_root}" ]] || return 0

  while IFS= read -r -d '' path; do
    normalize_synced_symlink "${src_root}" "${dest_root}" "${path}"
  done < <(find "${dest_root}" -type l -print0)

  return 0
}

normalize_changed_symlinks_from_rsync_output() {
  local src_root="$1"
  local dest_root="$2"
  local rsync_output="$3"
  local line=""
  local rel_path=""

  [[ -d "${dest_root}" ]] || return 0

  while IFS= read -r line; do
    [[ "${line}" == *" -> "* ]] || continue
    [[ "${line}" =~ ^.[L] ]] || continue
    rel_path="${line#* }"
    rel_path="${rel_path%% -> *}"
    normalize_synced_symlink "${src_root}" "${dest_root}" "${dest_root%/}/${rel_path}"
  done <<< "${rsync_output}"

  return 0
}

emit_preview_result() {
  local name="$1"
  local output="$2"

  log_info "Preview $name"
  if [[ -n "$output" ]]; then
    printf '%s\n' "$output"
  else
    echo "No changes."
  fi
}

emit_apply_result() {
  local name="$1"
  local output="$2"

  if [[ -n "$output" ]]; then
    log_success "Updated $name"
  else
    log_info "Unchanged $name"
  fi
}

run_rsync_transfer() {
  local name="$1"
  local log_failures="${2:-true}"
  local output_var="${3:-}"
  shift 3
  local output=""
  local -a rsync_args=("$@")

  if $DRY_RUN; then
    rsync_args+=(--dry-run --itemize-changes)
    if ! output=$(rsync "${rsync_args[@]}" 2>&1); then
      if [[ "${log_failures}" == true ]]; then
        log_error "Preview failed for $name"
        printf '%s\n' "$output" >&2
      fi
      return 1
    fi
    emit_preview_result "$name" "$output"
    return 0
  fi

  rsync_args+=(--itemize-changes)
  if ! output=$(rsync "${rsync_args[@]}" 2>&1); then
    if [[ "${log_failures}" == true ]]; then
      log_error "Sync failed for $name"
      printf '%s\n' "$output" >&2
    fi
    return 1
  fi

  if [[ -n "${output_var}" ]]; then
    printf -v "${output_var}" '%s' "$output"
  else
    emit_apply_result "$name" "$output"
  fi
}

require_rsync() {
  if ! command -v rsync &>/dev/null; then
    log_error "rsync is required (cp fallback removed). Install rsync and rerun."
    exit 1
  fi
}

require_sync_manifest() {
  if [[ -r "${SYNC_MANIFEST_SOURCE}" ]]; then
    SYNC_MANIFEST_FILE="${SYNC_MANIFEST_SOURCE}"
    return 0
  fi

  if [[ "${SYNC_MANIFEST_SOURCE}" == *$'\n'* || "${SYNC_MANIFEST_SOURCE}" =~ ^[[:space:]]*(#|dir\||file\||host\|) ]]; then
    SYNC_MANIFEST_TEMP_FILE="$(mktemp "${TMPDIR:-/tmp}/dotfiles-sync.manifest.XXXXXX")" || {
      log_error "Failed to create temporary manifest"
      exit 1
    }
    printf '%s\n' "${SYNC_MANIFEST_SOURCE}" > "${SYNC_MANIFEST_TEMP_FILE}"
    SYNC_MANIFEST_FILE="${SYNC_MANIFEST_TEMP_FILE}"
    return 0
  fi

  log_error "Sync manifest not found: ${SYNC_MANIFEST_SOURCE}"
  exit 1
}

load_sync_manifest() {
  local kind=""
  local rel_path=""
  local excludes=""
  local extra=""

  SYNC_MANIFEST_RECORDS=()
  while IFS='|' read -r kind rel_path excludes extra; do
    [[ -n "${kind}${rel_path}${excludes}${extra}" ]] || continue
    [[ "${kind}" == \#* ]] && continue
    [[ -z "${extra}" ]] || {
      log_error "Invalid manifest entry: ${kind}|${rel_path}|${excludes}|${extra}"
      exit 1
    }
    [[ -n "${rel_path}" ]] || {
      log_error "Invalid manifest entry: ${kind}|${rel_path}|${excludes}"
      exit 1
    }
    case "${rel_path}" in
      /* | *$'\n'* | *$'\r'*)
        log_error "Manifest path must be relative and single-line: ${rel_path}"
        exit 1
        ;;
      ..|../*|*/../*|*/..)
        log_error "Manifest path must not contain '..' segments: ${rel_path}"
        exit 1
        ;;
    esac

    case "${kind}" in
      dir | file | host)
        SYNC_MANIFEST_RECORDS+=("${kind}|${rel_path}|${excludes}")
        ;;
      *)
        log_error "Unknown manifest kind: ${kind}"
        exit 1
        ;;
    esac
  done < "${SYNC_MANIFEST_FILE}"
}

host_profile_is_valid() {
  local profile="${1:-}"
  [[ -n "${profile}" && "${profile}" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]
}

get_host_profile() {
  local profile=""

  if [[ -f "${HOST_PROFILE_STATE_FILE}" ]]; then
    read -r profile <"${HOST_PROFILE_STATE_FILE}" || true
  fi

  if [[ -n "${profile}" ]] && ! host_profile_is_valid "${profile}"; then
    log_warn "Ignoring invalid host profile in ${HOST_PROFILE_STATE_FILE}: ${profile}"
    return 1
  fi

  [[ -n "${profile}" ]] || return 1
  printf '%s\n' "${profile}"
}

remove_path() {
  local dest="$1"
  local name="$2"
  local rel_dest="${dest#"${DOTFILES_DIR}"/}"

  if $LIST_ONLY; then
    echo "PLAN ABSENT ${dest}"
    return
  fi

  if [[ ! -e "${dest}" && ! -L "${dest}" ]]; then
    return
  fi

  if $DRY_RUN; then
    emit_preview_result "${name}" "*deleting   ${rel_dest}"
    return
  fi

  rm -rf -- "${dest}"
  log_success "Removed ${name}"
}

sync_host_profile_files() {
  local profile="${ACTIVE_HOST_PROFILE}"
  local host_root=""
  local kind=""
  local rel_path=""
  local excludes=""
  local record=""
  local -a host_paths=()

  if [[ -n "${profile}" ]]; then
    host_root="${DOTFILES_DIR}/hosts/${profile}"
  else
    log_warn "No host profile selected; managed host-specific files will not be saved. Use dotfiles-host-profile set <profile>."
  fi

  for record in "${SYNC_MANIFEST_RECORDS[@]}"; do
    IFS='|' read -r kind rel_path excludes <<< "${record}"
    [[ "${kind}" == "host" ]] || continue
    host_paths+=("${rel_path}")
  done

  if [[ -z "${host_root}" ]]; then
    return
  fi

  for rel_path in "${host_paths[@]}"; do
    remove_path "${DOTFILES_DIR}/${rel_path}" "root host file ${rel_path}"
  done

  if $LIST_ONLY; then
    log_info "Planning host profile mappings (${profile})..."
  else
    log_info "Syncing host profile '${profile}'..."
  fi

  for rel_path in "${host_paths[@]}"; do
    copy_path file "${HOME}/${rel_path}" "${host_root}/${rel_path}" "hosts/${profile}/${rel_path}"
  done
}

# Create dotfiles directory structure
create_dirs() {
  local dirs=(
    "$DOTFILES_DIR/.config"
    "$DOTFILES_DIR/.local/bin"
    "$DOTFILES_DIR/.local/lib"
    "$DOTFILES_DIR/.local/share"
    "$DOTFILES_DIR/hosts"
  )

  for dir in "${dirs[@]}"; do
    if $LIST_ONLY; then
      echo "PLAN DIR    $dir"
    elif $DRY_RUN; then
      echo "Would create: $dir"
    else
      mkdir -p "$dir"
    fi
  done
}

copy_path() {
  local kind="$1"
  local src="$2"
  local dest="$3"
  local name="$4"
  shift 4
  local extra_excludes=("$@")
  local exclude_pattern=""
  local exclude_preview=""
  local transfer_output=""
  local -a rsync_args=(-a --mkpath)

  if $LIST_ONLY; then
    if [[ "${kind}" == "dir" ]] && ((${#extra_excludes[@]})); then
      exclude_preview="$(printf '%s, ' "${extra_excludes[@]}")"
      exclude_preview="${exclude_preview%, }"
      echo "PLAN DIR    $src -> $dest (exclude: $exclude_preview)"
    else
      printf 'PLAN %-6s %s -> %s\n' "${kind^^}" "$src" "$dest"
    fi
    return
  fi

  if [[ "${kind}" == "dir" ]]; then
    if [[ ! -e "$src" ]]; then
      log_warn "Skipping $name (not found: $src)"
      return
    fi

    if [[ -d "$src" ]]; then
      rsync_args+=(
        --delete
        --delete-excluded
        --exclude='.git'
        --exclude='__pycache__'
        --exclude='*.pyc'
        --exclude='node_modules'
        --exclude='.cache'
        --exclude='lazy-lock.json'
      )
      for exclude_pattern in "${extra_excludes[@]}"; do
        rsync_args+=(--exclude="$exclude_pattern")
      done
      run_rsync_transfer "$name" true transfer_output "${rsync_args[@]}" "$src"/ "$dest"/
      normalize_changed_symlinks_from_rsync_output "$src" "$dest" "$transfer_output"
      emit_apply_result "$name" "$transfer_output"
      return
    fi

    kind="file"
  fi

  if [[ ! -e "$src" && ! -L "$src" ]]; then
    if [[ -e "$dest" || -L "$dest" ]]; then
      if $DRY_RUN; then
        emit_preview_result "$name" "*deleting   $(basename "$dest")"
      else
        rm -rf -- "$dest"
        log_success "Removed stale $name"
      fi
    else
      log_warn "Skipping $name (not found: $src)"
    fi
    return
  fi

  if [[ -d "$dest" && ! -L "$dest" ]]; then
    if $DRY_RUN; then
      emit_preview_result "$name" $'*deleting   '"$(basename "$dest")"$'\n>f+++++++++ '"$(basename "$dest")"
      return
    fi
    rm -rf -- "$dest"
  fi

  if run_rsync_transfer "$name" false transfer_output "${rsync_args[@]}" "$src" "$dest"; then
    normalize_synced_internal_symlinks "$src" "$dest"
    emit_apply_result "$name" "$transfer_output"
    return 0
  fi

  return 1
}

sync_manifest_mappings() {
  local section="${1:-all}"
  local kind=""
  local rel_path=""
  local excludes=""
  local record=""
  local -a extra_excludes=()

  for record in "${SYNC_MANIFEST_RECORDS[@]}"; do
    IFS='|' read -r kind rel_path excludes <<< "${record}"
    case "${section}" in
      config)
        [[ "${rel_path}" == .local/* ]] && continue
        ;;
      local)
        [[ "${rel_path}" == .local/* ]] || continue
        ;;
    esac

    extra_excludes=()
    if [[ -n "${excludes}" ]]; then
      IFS=',' read -r -a extra_excludes <<< "${excludes}"
    fi

    case "${kind}" in
      dir)
        copy_path dir "${HOME}/${rel_path}" "${DOTFILES_DIR}/${rel_path}" "${rel_path}" "${extra_excludes[@]}"
        ;;
      file)
        copy_path file "${HOME}/${rel_path}" "${DOTFILES_DIR}/${rel_path}" "${rel_path}"
        ;;
      host)
        ;;
    esac
  done
}

echo "========================================="
echo "  Dotfiles Sync"
echo "========================================="
echo "Target: $DOTFILES_DIR"
if ACTIVE_HOST_PROFILE="$(get_host_profile)"; then
  echo "Host profile: ${ACTIVE_HOST_PROFILE}"
else
  ACTIVE_HOST_PROFILE=""
  echo "Host profile: (not set)"
fi
$DRY_RUN && echo "(DRY RUN - no changes will be made)"
$LIST_ONLY && echo "(LIST MODE - plan only, no checks or filesystem writes)"
echo

if ! $LIST_ONLY; then
  require_rsync
fi
require_sync_manifest
load_sync_manifest

# Create directory structure
if $LIST_ONLY; then
  log_info "Planning directory structure..."
else
  log_info "Creating directory structure..."
fi
create_dirs
echo

# ~/.config directories
if $LIST_ONLY; then
  log_info "Planning ~/.config mappings..."
else
  log_info "Syncing ~/.config..."
fi

sync_manifest_mappings config
sync_host_profile_files

echo

# ~/.local directories
if $LIST_ONLY; then
  log_info "Planning ~/.local mappings..."
else
  log_info "Syncing ~/.local..."
fi

sync_manifest_mappings local

echo
echo "========================================="
if $LIST_ONLY; then
  echo "List complete."
elif $DRY_RUN; then
  echo "Dry run complete. Run without --dry-run to apply."
else
  log_success "Dotfiles sync complete!"
  echo "Location: $DOTFILES_DIR"
fi
echo "========================================="
