#!/usr/bin/env bash
#
# hyprshell — Bootstrap the Hypr shell environment and dispatch commands.
#
# Usage: hyprshell <command> [args...]
# Depends on: hypr runtime init and shell libraries
#
# Sourceable bootstrap; strict mode is owned by the caller or dispatched script.

resolve_executable_path() {
  local candidate="${EXECUTABLE:-hyprshell}"

  if [[ "${candidate}" == */* ]] && [[ -e "${candidate}" ]]; then
    realpath "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}"
    return
  fi

  command -v "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}"
}

if [[ -z "${BASH_SOURCE[0]}" ]]; then
  EXECUTABLE="${0}"
else
  EXECUTABLE="${BASH_SOURCE[0]}"
fi

BIN_DIR="$(dirname "$(resolve_executable_path)")"
LIB_DIR="$(realpath "${BIN_DIR}/../lib")"
runtime_init="${LIB_DIR}/hypr/runtime/init.bash"

[[ -r "${runtime_init}" ]] || {
  printf 'Error: missing lib %s\n' "${runtime_init}" >&2
  exit 1
}

# shellcheck source=/dev/null
source "${runtime_init}" || exit 1
unset runtime_init

hyprshell_prepend_path() {
  local entry=""
  local prefix=""

  for entry in "$@"; do
    [[ -n "${entry}" ]] || continue
    case ":${PATH}:" in
      *":${entry}:"*) continue ;;
    esac
    prefix="${prefix:+${prefix}:}${entry}"
  done

  PATH="${prefix:+${prefix}:}${PATH}"
}

hyprshell_prepend_path "${XDG_CONFIG_HOME}/hypr/scripts" "${BIN_DIR}" "${HYPR_LIB_DIR}"

HYPR_SCRIPTS_PATH="${HYPR_SCRIPTS_PATH:-${XDG_CONFIG_HOME}/hypr/scripts:${LIB_DIR}/hypr}:${XDG_DATA_HOME}/waybar/scripts:${XDG_CONFIG_HOME}/waybar/scripts"

export BIN_DIR LIB_DIR PATH HYPR_SCRIPTS_PATH

if [[ "${BASH_SOURCE[0]}" == "${0}" && "${1:-}" == "app" ]]; then
  export PATH="${HYPR_SCRIPTS_PATH}:${PATH}"
  if [[ "${HYPRPY:-0}" =~ ^[0-9]+$ && "${HYPRPY:-0}" -eq 1 ]]; then
    # shellcheck source=/dev/null
    source "${LIB_DIR}/hypr/shell/lib/hyprshell.python.bash" || exit 1
    python_activate
  fi
  shift
  exec "${HYPR_LIB_DIR}/system/app2unit.sh" "$@"
fi

for hyprshell_lib in \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.runner.bash" \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.python.bash" \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.completion.bash" \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.commands.bash"; do
  if [[ ! -r "${hyprshell_lib}" ]]; then
    echo "Error: missing lib ${hyprshell_lib}" >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  source "${hyprshell_lib}" || exit 1
done

if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
  if ! hypr_runtime_bootstrap; then
    echo "Error: Could not load config, broken installation?"
    return 1
  fi
  return 0
fi

case "${1:-}" in
  init | --init)
    initialized
    exit 0
    ;;
  lock-session)
    lock_session
    exit 0
    ;;
  *)
    export HYPR_SHELL_INIT=1
    ;;
esac

case "${1:-}" in
  logout)
    hyprlogout
    ;;
  pypr)
    run_pypr "$@"
    exit 0
    ;;
  pip)
    run_pip "$@"
    exit 0
    ;;
  -r | reload)
    hyprreload
    ;;
  --release-notes | release-notes)
    get_release_notes
    ;;
  --version | version | -v)
    get_version
    ;;
  --help | help | -h)
    USAGE
    ;;
  list | --list-script)
    list_script
    ;;
  --list-script-path)
    list_script_path
    ;;
  --completions)
    shift
    generate_completions "${1:-}"
    ;;
  validate)
    shift
    parse_config="${HYPR_LIB_DIR}/util/parse.config.py"
    if [[ -x "${parse_config}" ]]; then
      "${parse_config}" --input "$XDG_CONFIG_HOME/hypr/config.toml" --env "$XDG_STATE_HOME/hypr/env-overrides" --hypr "$XDG_STATE_HOME/hypr/hyprland.conf" --export "$@"
    else
      echo "parse.config.py not found at ${parse_config}"
    fi
    exit 0
    ;;
  pyinit)
    python_initialized
    ;;
  *)
    run_command "$@"
    ;;
esac
