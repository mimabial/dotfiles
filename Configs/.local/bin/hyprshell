#!/usr/bin/env bash
# shellcheck disable=SC1091

# hyprshell entrypoint: environment bootstrap + command dispatch.

resolve_executable_path() {
  local candidate="${EXECUTABLE:-hyprshell}"

  if [[ "${candidate}" == */* ]] && [[ -e "${candidate}" ]]; then
    realpath "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}"
    return
  fi

  command -v "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}"
}

hyprshell_source_lib() {
  local lib_file="$1"
  if [[ ! -r "${lib_file}" ]]; then
    echo "Error: missing lib ${lib_file}" >&2
    return 1
  fi
  # shellcheck source=/dev/null
  source "${lib_file}"
}

if [[ -z "${BASH_SOURCE[0]}" ]]; then
  EXECUTABLE="${0}"
else
  EXECUTABLE="${BASH_SOURCE[0]}"
fi

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

BIN_DIR="$(dirname "$(resolve_executable_path)")"
LIB_DIR="$(realpath "${BIN_DIR}/../lib")"

HYPR_LIB_PATH="${LIB_DIR}/hypr"
for subdir in "${HYPR_LIB_PATH}"/*/; do
  [[ -d "${subdir}" ]] && HYPR_LIB_PATH="${HYPR_LIB_PATH}:${subdir}"
done

PATH="${XDG_CONFIG_HOME}/hypr/scripts:${BIN_DIR}:${HYPR_LIB_PATH}:${PATH}"
HYPR_SCRIPTS_PATH="${HYPR_SCRIPTS_PATH:-${XDG_CONFIG_HOME}/hypr/scripts:${LIB_DIR}/hypr}:${XDG_DATA_HOME}/waybar/scripts:${XDG_CONFIG_HOME}/waybar/scripts"

export BIN_DIR LIB_DIR PATH HYPR_SCRIPTS_PATH

hyprshell_source_lib "${LIB_DIR}/hypr/shell/lib/hyprshell.runner.bash" || exit 1
hyprshell_source_lib "${LIB_DIR}/hypr/shell/lib/hyprshell.python.bash" || exit 1
hyprshell_source_lib "${LIB_DIR}/hypr/shell/lib/hyprshell.completion.bash" || exit 1
hyprshell_source_lib "${LIB_DIR}/hypr/shell/lib/hyprshell.commands.bash" || exit 1

case "$1" in
  app)
    export PATH="${HYPR_SCRIPTS_PATH}:${PATH}"
    if [[ "${HYPRPY:-0}" =~ ^[0-9]+$ ]] && [[ "${HYPRPY:-0}" -eq 1 ]]; then
      python_activate
    fi
    shift
    exec app2unit.sh "$@"
    ;;
  init | --init)
    initialized
    exit 0
    ;;
  lock-session)
    lock_session
    exit 0
    ;;
  *)
    export HYPR_SHELL_INIT=1
    ;;
esac

if ! source "${LIB_DIR}/hypr/globalcontrol.sh"; then
  echo "Error: Could not load config, broken installation?"
  exit 1
fi

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  case "$1" in
    logout)
      hyprlogout
      ;;
    pypr)
      run_pypr "$@"
      exit 0
      ;;
    pip)
      run_pip "$@"
      exit 0
      ;;
    -r | reload)
      hyprreload
      ;;
    --release-notes | release-notes)
      get_release_notes
      ;;
    --version | version | -v)
      get_version
      ;;
    --help | help | -h)
      USAGE
      ;;
    --list-script)
      list_script
      ;;
    --list-script-path)
      list_script_path
      ;;
    --completions)
      shift
      generate_completions "$1"
      ;;
    validate)
      shift
      if command -v parse.config.py >/dev/null 2>&1; then
        parse.config.py --input "$XDG_CONFIG_HOME/hypr/config.toml" --env "$XDG_STATE_HOME/hypr/config" --hypr "$XDG_STATE_HOME/hypr/hyprland.conf" "$@"
      else
        echo "parse.config.py not found. Please make sure it is in \$PATH."
      fi
      exit 0
      ;;
    pyinit)
      python_initialized
      ;;
    "")
      for func in $(compgen -A function); do
        export -f "${func?}"
      done
      ;;
    *)
      run_command "$@"
      ;;
  esac
fi
