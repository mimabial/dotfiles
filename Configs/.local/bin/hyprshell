#!/usr/bin/env bash

# hyprshell entrypoint: environment bootstrap + command dispatch.

resolve_executable_path() {
  local candidate="${EXECUTABLE:-hyprshell}"

  if [[ "${candidate}" == */* ]] && [[ -e "${candidate}" ]]; then
    realpath "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}"
    return
  fi

  command -v "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}"
}

if [[ -z "${BASH_SOURCE[0]}" ]]; then
  EXECUTABLE="${0}"
else
  EXECUTABLE="${BASH_SOURCE[0]}"
fi

BIN_DIR="$(dirname "$(resolve_executable_path)")"
LIB_DIR="$(realpath "${BIN_DIR}/../lib")"
runtime_init="${LIB_DIR}/hypr/runtime/init.bash"

[[ -r "${runtime_init}" ]] || {
  printf 'Error: missing lib %s\n' "${runtime_init}" >&2
  exit 1
}

# shellcheck source=/dev/null
source "${runtime_init}" || exit 1
unset runtime_init

HYPR_LIB_PATH="${HYPR_LIB_DIR}"
for subdir in "${HYPR_LIB_PATH}"/*/; do
  [[ -d "${subdir}" ]] && HYPR_LIB_PATH="${HYPR_LIB_PATH}:${subdir}"
done

PATH="${XDG_CONFIG_HOME}/hypr/scripts:${BIN_DIR}:${HYPR_LIB_PATH}:${PATH}"
HYPR_SCRIPTS_PATH="${HYPR_SCRIPTS_PATH:-${XDG_CONFIG_HOME}/hypr/scripts:${LIB_DIR}/hypr}:${XDG_DATA_HOME}/waybar/scripts:${XDG_CONFIG_HOME}/waybar/scripts"

export BIN_DIR LIB_DIR PATH HYPR_SCRIPTS_PATH

for hyprshell_lib in \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.runner.bash" \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.python.bash" \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.completion.bash" \
  "${LIB_DIR}/hypr/shell/lib/hyprshell.commands.bash"; do
  if [[ ! -r "${hyprshell_lib}" ]]; then
    echo "Error: missing lib ${hyprshell_lib}" >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  source "${hyprshell_lib}" || exit 1
done

if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
  # shellcheck source=/dev/null
  if ! source "${LIB_DIR}/hypr/globalcontrol.sh"; then
    echo "Error: Could not load config, broken installation?"
    return 1
  fi
  return 0
fi

case "${1:-}" in
  app)
    export PATH="${HYPR_SCRIPTS_PATH}:${PATH}"
    if [[ "${HYPRPY:-0}" =~ ^[0-9]+$ ]] && [[ "${HYPRPY:-0}" -eq 1 ]]; then
      python_activate
    fi
    shift
    exec app2unit.sh "$@"
    ;;
  init | --init)
    initialized
    exit 0
    ;;
  lock-session)
    lock_session
    exit 0
    ;;
  *)
    export HYPR_SHELL_INIT=1
    ;;
esac

case "${1:-}" in
  logout)
    hyprlogout
    ;;
  pypr)
    run_pypr "$@"
    exit 0
    ;;
  pip)
    run_pip "$@"
    exit 0
    ;;
  -r | reload)
    hyprreload
    ;;
  --release-notes | release-notes)
    get_release_notes
    ;;
  --version | version | -v)
    get_version
    ;;
  --help | help | -h)
    USAGE
    ;;
  --list-script)
    list_script
    ;;
  --list-script-path)
    list_script_path
    ;;
  --completions)
    shift
    generate_completions "${1:-}"
    ;;
  validate)
    shift
    if command -v parse.config.py >/dev/null 2>&1; then
      parse.config.py --input "$XDG_CONFIG_HOME/hypr/config.toml" --env "$XDG_STATE_HOME/hypr/env-overrides" --hypr "$XDG_STATE_HOME/hypr/hyprland.conf" --export "$@"
    else
      echo "parse.config.py not found. Please make sure it is in \$PATH."
    fi
    exit 0
    ;;
  pyinit)
    python_initialized
    ;;
  *)
    run_command "$@"
    ;;
esac
