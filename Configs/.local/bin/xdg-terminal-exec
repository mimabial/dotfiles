#!/usr/bin/env bash
set -euo pipefail

TERMINAL_TUI="${TERMINAL_TUI:-kitty}"
app_id=""
title=""
terminal_args=()
cmd=()

usage() {
  printf 'Usage: %s [--app-id ID] [--title TITLE] [--] [command [args...]]\n' "$(basename "$0")" >&2
}

require_arg() {
  local option="$1"
  local value="${2:-}"

  [[ -n "${value}" ]] && return 0
  printf 'Missing argument for %s\n' "${option}" >&2
  usage
  exit 2
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --app-id=*)
        app_id="${1#--app-id=}"
        shift
        ;;
      --app-id)
        require_arg "$1" "${2:-}"
        app_id="$2"
        shift 2
        ;;
      --title=*)
        title="${1#--title=}"
        shift
        ;;
      --title)
        require_arg "$1" "${2:-}"
        title="$2"
        shift 2
        ;;
      -h | --help)
        usage
        exit 0
        ;;
      --print-path | --print-cmd | --print-cmd=*)
        return 1
        ;;
      --)
        shift
        cmd=("$@")
        break
        ;;
      -*)
        terminal_args+=("$1")
        shift
        ;;
      *)
        cmd=("$@")
        break
        ;;
    esac
  done
}

build_command() {
  local terminal_name="${TERMINAL_TUI##*/}"
  local -n out_ref="$1"

  out_ref=("${TERMINAL_TUI}" "${terminal_args[@]}")
  case "${terminal_name}" in
    kitty)
      [[ -n "${app_id}" ]] && out_ref+=("--app-id=${app_id}")
      [[ -n "${title}" ]] && out_ref+=("--title=${title}")
      out_ref+=("${cmd[@]}")
      ;;
    alacritty)
      [[ -n "${app_id}" ]] && out_ref+=(--class "${app_id}")
      [[ -n "${title}" ]] && out_ref+=(--title "${title}")
      ((${#cmd[@]} > 0)) && out_ref+=(-e "${cmd[@]}")
      ;;
    *)
      ((${#cmd[@]} > 0)) && out_ref+=("${cmd[@]}")
      ;;
  esac
}

main() {
  local -a terminal_command=()

  parse_args "$@" || exit 1
  build_command terminal_command
  exec "${terminal_command[@]}"
}

main "$@"
