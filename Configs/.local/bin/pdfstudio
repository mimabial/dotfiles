#!/bin/sh

java_home_17=/usr/lib/jvm/java-17-openjdk

if [ ! -x "$java_home_17/bin/java" ]; then
  printf '%s\n' "PDF Studio needs Java 9 through 19, but this system currently defaults to Java 21." >&2
  printf '%s\n' "Install Java 17 with:" >&2
  printf '%s\n' "  sudo pacman -S --needed jre17-openjdk" >&2
  exit 1
fi

export INSTALL4J_JAVA_HOME="$java_home_17"
export INSTALL4J_JAVA_HOME_OVERRIDE="$java_home_17"

exec /usr/share/pdfstudio/pdfstudio2024 "$@"
