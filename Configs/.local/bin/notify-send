#!/usr/bin/env bash
set -euo pipefail

resolve_other_executable() {
  local command_name="$1"
  local self_path candidate resolved_candidate

  self_path="$(readlink -f -- "$0" 2>/dev/null || printf '%s\n' "$0")"
  while IFS= read -r candidate; do
    [[ -n "${candidate}" ]] || continue
    resolved_candidate="$(readlink -f -- "${candidate}" 2>/dev/null || printf '%s\n' "${candidate}")"
    [[ "${resolved_candidate}" == "${self_path}" ]] && continue
    [[ -x "${resolved_candidate}" ]] || continue
    printf '%s\n' "${resolved_candidate}"
    return 0
  done < <(type -aP "${command_name}" 2>/dev/null || true)

  return 1
}

real_dunstify="$(resolve_other_executable dunstify || true)"
if [[ -n "${real_dunstify}" ]]; then
  exec "${real_dunstify}" "$@"
fi

real_notify_send="$(resolve_other_executable notify-send || true)"
[[ -n "${real_notify_send}" ]] || {
  printf 'notify-send: unable to resolve real notify-send or dunstify\n' >&2
  exit 1
}

exec "${real_notify_send}" "$@"
