#!/usr/bin/env bash
set -euo pipefail

output_file="${HOME}/installed_packages.txt"

{
  printf '# Pacman packages (explicit, native)\n'
  if command -v pacman >/dev/null 2>&1; then
    pacman -Qenq
  fi

  printf '\n# AUR packages (explicit, foreign)\n'
  if command -v pacman >/dev/null 2>&1; then
    pacman -Qemq
  fi

  printf '\n# Flatpak packages\n'
  if command -v flatpak >/dev/null 2>&1; then
    flatpak list --app --columns=application
  fi
} >"${output_file}"
