#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"
tty="${2:-}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
process_name_script="${script_dir}/tmux-process-name"

if [[ -x "${process_name_script}" ]]; then
  resolved_cmd="$("${process_name_script}" "${tty}" "${cmd}" 2>/dev/null || true)"
  [[ -n "${resolved_cmd}" ]] && cmd="${resolved_cmd}"
fi

case "$cmd" in
  codex | claude | anthropic | aider)
    icon="󰚩"
    label="$cmd"
    ;;
  nvim | vim | vi | view)
    icon=""
    label="nvim"
    ;;
  zsh | bash | fish | sh)
    icon=""
    label="$cmd"
    ;;
  ssh:* | mosh:*)
    icon="󰣀"
    label="${cmd#*:}"
    ;;
  ssh | mosh)
    icon="󰣀"
    label="$cmd"
    ;;
  lazygit | git)
    icon="󰊢"
    label="$cmd"
    ;;
  ranger | yazi | lf)
    icon=""
    label="$cmd"
    ;;
  htop | btop | top)
    icon="󰓅"
    label="$cmd"
    ;;
  pytest | python | python3 | ipython)
    icon=""
    label="$cmd"
    ;;
  node | nodejs | npm | pnpm | yarn | bun | vite | next | deno | astro | tsx)
    icon=""
    label="$cmd"
    ;;
  cargo | rustc)
    icon=""
    label="$cmd"
    ;;
  docker | docker-compose | podman)
    icon=""
    label="$cmd"
    ;;
  tmux)
    icon=""
    label="$cmd"
    ;;
  "")
    icon=""
    label="shell"
    ;;
  *)
    icon=""
    label="$cmd"
    ;;
esac

printf '%s %s\n' " $icon" "$label "
