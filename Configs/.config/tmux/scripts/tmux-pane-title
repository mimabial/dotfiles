#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"

case "$cmd" in
  nvim | vim | vi | view)
    icon="¯ÿ½"
    label="nvim"
    ;;
  zsh | bash | fish | sh)
    icon="¯×ò"
    label="$cmd"
    ;;
  ssh | mosh)
    icon="¾░úÇ"
    label="$cmd"
    ;;
  lazygit | git)
    icon="¾░èó"
    label="$cmd"
    ;;
  ranger | yazi | lf)
    icon="´ü╝"
    label="$cmd"
    ;;
  htop | btop | top)
    icon="¾░ôà"
    label="$cmd"
    ;;
  python | python3 | ipython)
    icon="¯ÿå"
    label="$cmd"
    ;;
  node | nodejs | npm | pnpm | yarn | bun)
    icon="¯£ÿ"
    label="$cmd"
    ;;
  cargo | rustc)
    icon="¯×¿"
    label="$cmd"
    ;;
  docker | docker-compose | podman)
    icon="´îê"
    label="$cmd"
    ;;
  tmux)
    icon="¯»ê"
    label="$cmd"
    ;;
  "")
    icon="´äá"
    label="shell"
    ;;
  *)
    icon="´äá"
    label="$cmd"
    ;;
esac

printf '%s %s\n' " $icon"
