$HOME/.config/rofi/theme.rasi

* {
    background:          #1F1F28E6;
    background-alpha:    #1F1F2859;
    foreground:          #DCD7BAFF;
    border:              #957FB8FF;
    accent:              #7FB4CACC;
    selected-background: #7E9CD8FF;
    selected-foreground: #1F1F28FF;
    separator:           #72716940;
    urgent:              #C34043FF;
    active:              #76946AFF;
}
