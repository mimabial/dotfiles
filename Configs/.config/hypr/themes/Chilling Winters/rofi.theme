$HOME/.config/rofi/theme.rasi

* {
    background:          #f7ecec;
    background-alpha:    #d6caca59;
    foreground:          #2e2820;
    border:              #7fa1b5;
    accent:              #ff8c5a;
    selected-background: #5085a0;
    selected-foreground: #f7ecec;
    separator:           #d6caca;
    urgent:              #df7845;
    active:              #4e776b;
}
