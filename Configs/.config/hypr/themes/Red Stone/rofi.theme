$HOME/.config/rofi/theme.rasi
* {
    background: #121212;
    background-alpha:    #12121259;
    foreground: #c9b9a8;
    accent: #c15959;
    selected-background: #4E0405E6;
    selected-foreground: #FFCCCCE6;
    separator:           #80808080;
    urgent:              #3d3935;
    active:              #d47065;
    border: #3d3935;
}


