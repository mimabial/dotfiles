$HOME/.config/rofi/theme.rasi
* {
    background:           #EEE2D0FF;
    background-alpha:    #EEE2D059;
    foreground:           #376B8CFF;
    border:           #F7B500FF;
    accent:           #F7B500FF;
    selected-background:         #F4EEE3FF;
    selected-foreground:         #3C5478FF;
    separator:           #D8CCB880;
    urgent:              #CC2C24ff;
    active:              #6F9A84ff;
}
