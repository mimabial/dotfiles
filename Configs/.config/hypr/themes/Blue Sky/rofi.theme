$HOME/.config/rofi/theme.rasi
* {
    background:          #294052B3;
    background-alpha:    #29405259;
    foreground:          #CCE9FFE6;
    border:              #7F9FC2E6;
    accent:              #8BE6F0E6;
    selected-background: #CCE4FFCC;
    selected-foreground: #FFF8F0FF;
    separator:           #7F9FC240;
    urgent:              #F6BAC1FF;
    active:              #9AC5E6FF;
}
