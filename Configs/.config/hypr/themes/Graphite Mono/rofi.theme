$HOME/.config/rofi/theme.rasi
* {
    background:          #1C1917e6;
    background-alpha:    #1C191759;
    foreground:          #d9d9d9ff;
    border:              #a6a6a6ff;
    accent:              #595959cc;
    selected-background: #a6a6a6ff;
    selected-foreground: #1C1917ff;
    separator:           #80808080;
    urgent:              #a6a6a6ff;
    active:              #595959cc;
}
