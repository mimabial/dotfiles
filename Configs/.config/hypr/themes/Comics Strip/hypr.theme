$HOME/.config/hypr/themes/theme.conf|> $HOME/.config/hypr/themes/colors.conf
$ICON_THEME = Tela-red-dark
$COLOR_SCHEME = prefer-dark
$CURSOR_THEME=ComixCursors-Black
$CURSOR_SIZE=29


general {
    gaps_in = 4
    gaps_out = 8
    border_size = 2
    col.active_border = rgba(c74b8aff)
    col.inactive_border = rgba(462f4acc)
    layout = dwindle
    resize_on_border = true
}

group {
    col.border_active = rgba(c74b8aff)
    col.border_inactive = rgba(462f4acc)
    col.border_locked_active = rgba(d32d38ff)
    col.border_locked_inactive = rgba(462f4acc)
}

decoration {
    rounding = 4
    shadow:enabled = false

    blur {
        enabled = yes
        size = 6
        passes = 3
        new_optimizations = on
        ignore_opacity = on
        xray = false
    }
}

layerrule = blur on, match:namespace waybar
