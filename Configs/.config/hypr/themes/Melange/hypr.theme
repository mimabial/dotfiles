$HOME/.config/hypr/themes/theme.conf|> $HOME/.config/hypr/themes/colors.conf

$ICON_THEME = Fluent-light
$COLOR_SCHEME = prefer-light
$NVIM_SCHEME = melange
$NVIM_VARIANT = light
$NVIM_BACKGROUND = light
$NVIM_TRANSPARENCY = false

$CURSOR_THEME = BreezeX-Dark
$CURSOR_SIZE = 28

general {
    gaps_in = 4
    gaps_out = 8
    border_size = 2
    col.active_border = rgba(AD8A3Eff)
    col.inactive_border = rgba(C4B19Ecc)
    layout = dwindle
    resize_on_border = true
}

group {
    col.border_active = rgba(AD8A3Eff)
    col.border_inactive = rgba(C4B19Ecc)
    col.border_locked_active = rgba(AD8A3Eff)
    col.border_locked_inactive = rgba(C4B19Ecc)
}

decoration {
    rounding = 3
    shadow:enabled = false

    blur {
        enabled = yes
        size = 6
        passes = 3
        new_optimizations = on
        ignore_opacity = on
        xray = false
    }
}

layerrule = blur on, match:namespace waybar
