{
    "label": "lock",
    "action": "hyprshell lock-screen.sh",
    "text": "Lock",
    "keybind": "l"
}

{
    "label": "logout",
    "action": "hyprshell logout",
    "text": "Logout",
    "keybind": "e"
}

{
    "label": "suspend",
    "action": "hyprshell lock-screen.sh & systemctl suspend",
    "text": "Suspend",
    "keybind": "u"
}

{
    "label": "shutdown",
    "action": "hyprshell cmd/powerctl.sh shutdown",
    "text": "Shutdown",
    "keybind": "s"
}

{
    "label": "hibernate",
    "action": "systemctl hibernate",
    "text": "Hibernate",
    "keybind": "h"
}

{
    "label": "reboot",
    "action": "hyprshell cmd/powerctl.sh reboot",
    "text": "Reboot",
    "keybind": "r"
}
