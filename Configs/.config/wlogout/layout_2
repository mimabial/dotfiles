{
    "label": "lock",
    "action": "hyprshell lock-screen.sh",
    "text": "Lock",
    "keybind": "l"
}

{
    "label": "logout",
    "action": "hyprshell logout",
    "text": "Logout",
    "keybind": "e"
}

{
    "label": "shutdown",
    "action": "hyprshell system/powerctl.sh shutdown",
    "text": "Shutdown",
    "keybind": "s"
}

{
    "label": "reboot",
    "action": "hyprshell system/powerctl.sh reboot",
    "text": "Reboot",
    "keybind": "r"
}
